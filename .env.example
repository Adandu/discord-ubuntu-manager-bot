# --- Discord Configuration ---
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here

# --- Bot Features ---
ENABLE_DOCKER=false # Set to true to enable /docker command group

# --- Server List (Numbered Format) ---
# You can add as many servers as you want by incrementing the number (1, 2, 3...)

# Server 1
DISCORD_UBUNTU_SERVER_ALIAS_1=web-prod
DISCORD_UBUNTU_SERVER_IP_1=1.2.3.4
DISCORD_UBUNTU_SERVER_USER_1=ubuntu
DISCORD_UBUNTU_SERVER_AUTH_METHOD_1=key
# For 'key', you can provide the raw key string OR a file path inside the container:
DISCORD_UBUNTU_SERVER_KEY_1=/app/ssh_keys/prod.key

# Server 2
DISCORD_UBUNTU_SERVER_ALIAS_2=db-01
DISCORD_UBUNTU_SERVER_IP_2=10.0.0.5
DISCORD_UBUNTU_SERVER_USER_2=admin
DISCORD_UBUNTU_SERVER_AUTH_METHOD_2=password
DISCORD_UBUNTU_SERVER_PASSWORD_2=your_secure_password_here

# --- Legacy Configuration (v0.1.0) ---
# SERVERS_JSON is still supported but individual variables above are preferred.
# SERVERS_JSON='[{"alias": "web-prod", ...}]'
